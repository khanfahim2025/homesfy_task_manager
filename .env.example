# Server
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173
API_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskmanager

# Session
SESSION_SECRET=change-me-to-a-long-random-string

# Auth (email + password — no SMTP required)
ALLOWED_EMAIL_DOMAIN=yourcompany.com
BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
BOOTSTRAP_ADMIN_PASSWORD=changeme123
BOOTSTRAP_MEMBER_PASSWORD=member12345
# Set to true to allow self-registration on the login page
ALLOW_SIGNUP=false

# Magic link / invite token TTL
TOKEN_TTL_SET_PASSWORD_HOURS=48
TOKEN_TTL_LOGIN_MINUTES=15

# AWS S3 (attachments) — AWS_REGION must match the bucket's region
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=your-task-manager-bucket

# Media uploads (default 100MB) — local folder when S3 is not set
MAX_UPLOAD_BYTES=104857600
UPLOAD_DIR=./uploads

# Timezone for due dates / overdue
TZ=Asia/Kolkata
