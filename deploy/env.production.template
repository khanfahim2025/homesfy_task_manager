# Copy to server/.env on EC2: cp deploy/env.production.template server/.env
# Then edit values marked CHANGE_ME

NODE_ENV=production
PORT=3001
APP_URL=https://tasks.homesfy.in
API_URL=https://tasks.homesfy.in

DATABASE_URL=postgresql://taskmanager:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/taskmanager
SESSION_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING

ALLOW_SIGNUP=false
ALLOWED_EMAIL_DOMAIN=homesfy.in

BOOTSTRAP_ADMIN_EMAIL=fahim.khan@homesfy.in
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
BOOTSTRAP_MEMBER_PASSWORD=CHANGE_ME_MEMBER_PASSWORD

TOKEN_TTL_SET_PASSWORD_HOURS=48
TOKEN_TTL_LOGIN_MINUTES=15

# S3 bucket is in us-east-1 (N. Virginia)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET=homesfy-task-manager

MAX_UPLOAD_BYTES=104857600
UPLOAD_DIR=/var/app/taskmanager/uploads
TZ=Asia/Kolkata
